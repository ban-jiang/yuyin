# 余音环境变量配置
# 本地开发复制此文件为 .env.local 并填入真实值

# DeepSeek API Key（必填，否则使用演示数据）
DEEPSEEK_API_KEY=sk-your-key-here

# DeepSeek 模型（可选，默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# 古文主版本模型（可选，不填时沿用 DEEPSEEK_MODEL）
DEEPSEEK_PROSE_MODEL=deepseek-chat

# 古文双重校验的审查模型（下一阶段启用）
DEEPSEEK_REVIEW_MODEL=deepseek-reasoner

# 诗泉 API 地址（可选，一般无需修改）
POETRY_API_BASE_URL=https://poetry.palemoky.com
